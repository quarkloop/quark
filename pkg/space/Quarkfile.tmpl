# Quarkfile - space definition
# https://quarkloop.com/docs/reference/quarkfile
quark: "1.0"

meta:
  name: %q
  description: ""
  version: "0.1.0"
  author: ""
  labels: {}

plugins:
  - ref: quark/tool-bash

permissions:
  filesystem:
    allowed_paths: ["."]
    read_only: ["Quarkfile"]
  network:
    allowed_hosts: ["*"]
    deny: ["169.254.0.0/16"]
  tools:
    allowed: ["*"]
    denied: []
  audit:
    log_tool_calls: true
    log_llm_responses: false
    retention_days: 30

capabilities:
  spawn_agents: true
  max_workers: 3
  create_plans: true
  approval_policy: auto

model:
  provider: anthropic
  name: claude-sonnet-4
  env:
    - ANTHROPIC_API_KEY

gateway:
  token_budget_per_hour: 100000
