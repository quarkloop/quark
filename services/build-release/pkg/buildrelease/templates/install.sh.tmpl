#!/usr/bin/env bash
# {{.PackageName}} installer
# Generated: {{.Date}}
# Version: {{.Version}}
set -euo pipefail

PACKAGE="{{.PackageName}}"
VERSION="{{.Version}}"
BINARY="{{.BinaryName}}"
INSTALL_DIR="{{.InstallDir}}"
HOMEPAGE="{{.Homepage}}"

detect_platform() {
  OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
  ARCH="$(uname -m)"

  case "$OS" in
    linux) OS="linux" ;;
    darwin) OS="darwin" ;;
    *) echo "Unsupported OS: $OS"; exit 1 ;;
  esac

  case "$ARCH" in
    x86_64|amd64) ARCH="amd64" ;;
    arm64|aarch64) ARCH="arm64" ;;
    armv7l) ARCH="arm"; ARM="7" ;;
    *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
  esac

  ARCHIVE="${PACKAGE}_${OS}_${ARCH}.tar.gz"
  if [ -n "${ARM:-}" ]; then
    ARCHIVE="${PACKAGE}_${OS}_${ARCH}_v${ARM}.tar.gz"
  fi
}

download() {
  url="$1"
  out="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL --retry 3 -o "$out" "$url"
    return
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -q -O "$out" "$url"
    return
  fi
  echo "curl or wget is required"
  exit 1
}

main() {
  detect_platform
  base_url="${HOMEPAGE}/releases/download/v${VERSION}"
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT

  archive_path="${tmp_dir}/${ARCHIVE}"
  download "${base_url}/${ARCHIVE}" "$archive_path"
  tar -xzf "$archive_path" -C "$tmp_dir"

  mkdir -p "$INSTALL_DIR"
  install -m 0755 "${tmp_dir}/${BINARY}" "${INSTALL_DIR}/${BINARY}"
  echo "Installed ${BINARY} ${VERSION} to ${INSTALL_DIR}/${BINARY}"
}

main "$@"
