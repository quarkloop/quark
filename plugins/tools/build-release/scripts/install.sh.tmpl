#!/usr/bin/env bash
# {{.PackageName}} installer
# Generated: {{.Date}}
# Version:   {{.Version}}
set -euo pipefail

PACKAGE="{{.PackageName}}"
VERSION="{{.Version}}"
BINARY="{{.BinaryName}}"
INSTALL_DIR="{{.InstallDir}}"
HOMEPAGE="{{.Homepage}}"

# Detect latest version from GitHub API if not pinned
if [ "$VERSION" = "latest" ]; then
    if command -v curl >/dev/null 2>&1; then
        VERSION=$(curl -fsSL --retry 3 "https://api.github.com/repos/{{.RepoOwner}}/{{.RepoName}}/releases/latest" \
            | grep '"tag_name":' \
            | sed -E 's/.*"v([^"]+)".*/\1/')
    fi
fi

detect_platform() {
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)

    case "$OS" in
        linux)              OS="linux"   ;;
        darwin)             OS="darwin"  ;;
        *) echo "❌ Unsupported OS: $OS"; exit 1 ;;
    esac

    case "$ARCH" in
        x86_64|amd64) ARCH="amd64" ;;
        arm64|aarch64) ARCH="arm64" ;;
        armv7l) ARCH="arm"; ARM="7" ;;
        *) echo "❌ Unsupported architecture: $ARCH"; exit 1 ;;
    esac

    EXT="tar.gz"
    BIN="$BINARY"
    TARGET_DIR="$INSTALL_DIR"

    ARCHIVE="${PACKAGE}_${OS}_${ARCH}.${EXT}"
    if [ -n "${ARM:-}" ]; then
        ARCHIVE="${PACKAGE}_${OS}_${ARCH}v${ARM}.${EXT}"
    fi
}

retry_download() {
    URL="$1"
    OUT="$2"
    MAX_RETRIES=3
    DELAY=2

    for ((i=1; i<=MAX_RETRIES; i++)); do
        if command -v curl >/dev/null 2>&1; then
            if curl -fsSL --retry 3 ${AUTH_HEADER:+-H "$AUTH_HEADER"} -o "$OUT" "$URL" 2>&1; then
                return 0
            fi
        elif command -v wget >/dev/null 2>&1; then
            if wget -q --show-progress -O "$OUT" "$URL" 2>&1; then
                return 0
            fi
        else
            echo "❌ Error: curl or wget is required"
            exit 1
        fi

        if [ "$i" -lt "$MAX_RETRIES" ]; then
            echo "⚠️  Download failed (attempt $i/$MAX_RETRIES), retrying in ${DELAY}s..."
            sleep "$DELAY"
            DELAY=$((DELAY * 2))
        fi
    done

    echo "❌ Download failed after $MAX_RETRIES attempts"
    return 1
}

verify_checksum() {
    FILE="$1"
    EXPECTED="$2"

    if command -v sha256sum >/dev/null 2>&1; then
        GOT=$(sha256sum "$FILE" | awk '{print $1}')
    elif command -v shasum >/dev/null 2>&1; then
        GOT=$(shasum -a 256 "$FILE" | awk '{print $1}')
    else
        echo "⚠️  Skipping checksum verification (no sha256sum/shasum found)"
        return 0
    fi

    if [ "$GOT" != "$EXPECTED" ]; then
        echo "❌ Checksum mismatch!"
        echo "   Expected: $EXPECTED"
        echo "   Got:      $GOT"
        exit 1
    fi
    echo "✅ Checksum verified"
}

extract() {
    ARCHIVE="$1"
    DEST="$2"

    case "$ARCHIVE" in
        *.tar.gz) tar -xzf "$ARCHIVE" -C "$DEST" ;;
        *) echo "❌ Unknown archive format: $ARCHIVE"; exit 1 ;;
    esac
}

install_binary() {
    SRC="$1"
    DEST="$2"

    if [ -w "$DEST" ]; then
        mv "$SRC" "$DEST/"
        chmod +x "$DEST/$BIN"
    else
        echo "🔐 Elevated permissions required for $DEST"
        if command -v sudo >/dev/null 2>&1; then
            sudo mv "$SRC" "$DEST/"
            sudo chmod +x "$DEST/$BIN"
        else
            echo "❌ sudo not available. Please run as root or set INSTALL_DIR to a writable path"
            exit 1
        fi
    fi
    echo "✅ Installed $BINARY to $DEST/$BINARY"
}

main() {
    echo "🚀 Installing $PACKAGE v$VERSION..."

    detect_platform

    # Optional GitHub token for private repos / higher rate limits
    if [ -n "${GITHUB_TOKEN:-}" ]; then
        AUTH_HEADER="Authorization: token $GITHUB_TOKEN"
    fi

    BASE_URL="${HOMEPAGE}/releases/download/v${VERSION}"
    URL="${BASE_URL}/${ARCHIVE}"

    TMP_DIR=$(mktemp -d)
    trap 'rm -rf "$TMP_DIR"' EXIT

    ARCHIVE_PATH="${TMP_DIR}/${ARCHIVE}"
    echo "⬇️  Downloading from $URL..."
    retry_download "$URL" "$ARCHIVE_PATH"

    # Per-artifact checksum verification (embedded at release time)
    {{- range .Artifacts}}
    if [ "$ARCHIVE" = "{{.ArchiveName}}" ] && [ -n "{{.Checksum}}" ]; then
        verify_checksum "$ARCHIVE_PATH" "{{.Checksum}}"
    fi
    {{- end}}

    echo "📦 Extracting..."
    extract "$ARCHIVE_PATH" "$TMP_DIR"

    BIN_PATH="${TMP_DIR}/${BIN}"
    if [ ! -f "$BIN_PATH" ]; then
        echo "❌ Binary not found after extraction"
        exit 1
    fi

    install_binary "$BIN_PATH" "$TARGET_DIR"

    # Verify installation
    if command -v "$BINARY" >/dev/null 2>&1; then
        echo ""
        echo "🎉 Installation complete!"
        echo "   Version: $(${TARGET_DIR}/${BINARY} version 2>/dev/null || echo 'unknown')"
        echo ""
        echo "📖 Documentation: ${HOMEPAGE}"
    else
        echo ""
        echo "⚠️  $BINARY not found in PATH after installation"
        echo "   You may need to restart your shell or add $TARGET_DIR to PATH"
    fi
}

main "$@"
