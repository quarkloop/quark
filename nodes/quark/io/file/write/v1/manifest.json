{
    "uri": "quark/io/file/write:v1",
    "domain": "io",
    "subdomain": "file",
    "node": "write",
    "version": "1.0.0",
    "language": "java",
    "description": "Appends incoming messages as JSON Lines to a file on disk",
    "config": {
        "path": {
            "type": "string",
            "required": true,
            "description": "File path; parent directories are created automatically"
        },
        "mode": {
            "type": "string",
            "default": "append",
            "description": "Write mode (only 'append' is supported)"
        }
    },
    "events": [],
    "dependencies": {
        "java": [
            "com.quarkloop.quark:quark-core:0.1.0-SNAPSHOT",
            "org.slf4j:slf4j-api:2.0.6",
            "jakarta.enterprise:jakarta.enterprise.cdi-api:4.1.0",
            "com.fasterxml.jackson.core:jackson-databind:2.18.2",
            "com.fasterxml.jackson.core:jackson-core:2.18.2",
            "com.fasterxml.jackson.core:jackson-annotations:2.18.2",
            "com.fasterxml.jackson.datatype:jackson-datatype-jsr310:2.18.2"
        ]
    },
    "supportedRuntimes": [
        "jvm",
        "native"
    ]
}
