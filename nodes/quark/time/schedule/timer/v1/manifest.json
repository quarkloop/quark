{
    "uri": "quark/time/schedule/timer:v1",
    "domain": "time",
    "subdomain": "schedule",
    "node": "timer",
    "version": "1.0.0",
    "language": "java",
    "description": "Emits a tick event at a fixed interval",
    "config": {
        "interval": {
            "type": "string",
            "default": "1s",
            "description": "Duration like 1s, 500ms, 10s, 1m, 1h"
        }
    },
    "events": [
        "tick"
    ],
    "dependencies": {
        "java": [
            "com.quarkloop.quark:quark-core:0.1.0-SNAPSHOT",
            "org.slf4j:slf4j-api:2.0.6",
            "jakarta.enterprise:jakarta.enterprise.cdi-api:4.1.0"
        ]
    },
    "supportedRuntimes": [
        "jvm",
        "native"
    ]
}
