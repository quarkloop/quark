# LLM provider keys — declare which you use in your Quarkfile env: section
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ZHIPU_API_KEY=

# Web search (optional — stub response returned if absent)
BRAVE_API_KEY=
SERPAPI_KEY=

# E2E tests — set one provider key and optionally override the model
# OPENROUTER_E2E_MODEL=openai/gpt-4o-mini
# ZHIPU_E2E_MODEL=GLM-4.7-Flash

# Override the api-server address used by all CLI commands
# QUARK_API_SERVER=http://127.0.0.1:7070
